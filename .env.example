# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
# Use the Supavisor pooler URL (IPv4-friendly):
# postgresql://postgres.{ref}:{pwd}@aws-1-{region}.pooler.supabase.com:5432/postgres
DATABASE_URL=your_postgres_connection_string_here

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex master key. Bootstrap once into vault.secrets via:
#   SELECT vault.create_secret('<hex>', 'medina_master_encryption_key', '...');
# See plans/fix-encryption-vault.md for details.
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Medina

# ─── AI / Mastra ──────────────────────────────────────────────────────────────
# AI-1: OpenRouter is the single LLM provider — agent_configs.model holds
# OpenRouter ids (e.g. 'anthropic/claude-sonnet-4-5', 'openai/gpt-4o').
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenAI raw SDK key — used by packages/ai/embeddings.ts (RAG, AI-3).
OPENAI_API_KEY=your_openai_api_key_here
# Legacy / optional: only if you bypass OpenRouter for a direct Anthropic call.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Mastra agent storage — wired in AI-3 (RAG + memory).
MASTRA_POSTGRES_URL=your_postgres_connection_string_here
MASTRA_TELEMETRY_ENABLED=false

# ─── Langfuse observability ───────────────────────────────────────────────────
# Tracing of every dispatchAgent run: input, output, tokens, latency, cost.
# Failsafe: if these are unset OR Langfuse is unreachable, the agent still runs;
# only telemetry is dropped.
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Workers / Inngest ────────────────────────────────────────────────────────
# Local development: leave EVENT_KEY and SIGNING_KEY UNSET (or commented) and
# set INNGEST_DEV=1 to put both the client and the serve handler in dev mode.
# The local Inngest CLI (`npx inngest-cli@latest dev` on :8288) handles
# dispatch and signature verification.
#
# Production (Vercel): set EVENT_KEY + SIGNING_KEY from the Inngest cloud
# dashboard; do NOT set INNGEST_DEV.
INNGEST_DEV=1
# Set only in production (Vercel). Local dev uses Inngest CLI.
# INNGEST_EVENT_KEY=your_inngest_event_key_here
# INNGEST_SIGNING_KEY=your_inngest_signing_key_here

# ─── Realtime (Centrifugo) ────────────────────────────────────────────────────
# WS URL exposed to the browser. Falls through Cloudflare to ws.medinacrm.com.
NEXT_PUBLIC_CENTRIFUGO_WSS_URL=wss://ws.medinacrm.com/connection/websocket

# Server-side admin API used by webhook + workers to fire-and-forget publish.
CENTRIFUGO_API_URL=https://ws.medinacrm.com/api
# Secrets — fill from the cofre. CENTRIFUGO_JWT_HMAC_SECRET must match the
# token_hmac_secret_key configured in the VPS centrifugo.json EXACTLY (no
# trailing newline).
# CENTRIFUGO_API_KEY=your_centrifugo_api_key_here
# CENTRIFUGO_JWT_HMAC_SECRET=your_centrifugo_jwt_hmac_secret_here

# Set 'false' to bypass Centrifugo entirely (kill switch). Polling fallback
# inside conversation-detail still triggers based on hasActiveMessages.
NEXT_PUBLIC_REALTIME_ENABLED=true
