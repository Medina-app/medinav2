# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
# Use the Supavisor pooler URL (IPv4-friendly):
# postgresql://postgres.{ref}:{pwd}@aws-1-{region}.pooler.supabase.com:5432/postgres
DATABASE_URL=your_postgres_connection_string_here

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex master key. Bootstrap once into vault.secrets via:
#   SELECT vault.create_secret('<hex>', 'medina_master_encryption_key', '...');
# See plans/fix-encryption-vault.md for details.
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Medina

# ─── AI / Mastra ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
MASTRA_POSTGRES_URL=your_postgres_connection_string_here
MASTRA_TELEMETRY_ENABLED=false

# ─── Workers / Inngest ────────────────────────────────────────────────────────
# Local development: leave EVENT_KEY and SIGNING_KEY UNSET (or commented) and
# set INNGEST_DEV=1 to put both the client and the serve handler in dev mode.
# The local Inngest CLI (`npx inngest-cli@latest dev` on :8288) handles
# dispatch and signature verification.
#
# Production (Vercel): set EVENT_KEY + SIGNING_KEY from the Inngest cloud
# dashboard; do NOT set INNGEST_DEV.
INNGEST_DEV=1
# Set only in production (Vercel). Local dev uses Inngest CLI.
# INNGEST_EVENT_KEY=your_inngest_event_key_here
# INNGEST_SIGNING_KEY=your_inngest_signing_key_here
