# apps/web/.env.example — overrides + web-only vars
#
# Most env vars are shared with the root .env.example; copy that file first.
# This file documents the vars that apps/web specifically reads (Next.js
# only loads .env.local from the same directory as the app, so during local
# development copy your secrets into apps/web/.env.local — not the root one).

# ─── AI providers (required for the inbox agent + Langfuse traces) ──────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── Langfuse observability ─────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Inngest (production: set both keys; local: leave commented + INNGEST_DEV=1) ──
# INNGEST_EVENT_KEY=your_inngest_event_key_here
# INNGEST_SIGNING_KEY=your_inngest_signing_key_here
INNGEST_DEV=1

# ─── Realtime (Centrifugo) ──────────────────────────────────────────────────
NEXT_PUBLIC_CENTRIFUGO_WSS_URL=wss://ws.medinacrm.com/connection/websocket
NEXT_PUBLIC_REALTIME_ENABLED=true
CENTRIFUGO_API_URL=https://ws.medinacrm.com/api
# CENTRIFUGO_API_KEY=your_centrifugo_api_key_here
# CENTRIFUGO_JWT_HMAC_SECRET=your_centrifugo_jwt_hmac_secret_here
